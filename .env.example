# Copy this to `.env` (gitignored) for LOCAL development.
# Point the app at your locally-running hobo-enterprise web (next dev on :3000),
# exposed publicly over HTTPS via ngrok. No trailing slash, no /api.
#
# 1) Run the web:    cd ../hobo-enterprise && npm run dev      (serves on :3000)
# 2) Run ngrok:      ngrok http 3000                            (gives an https URL)
# 3) Paste it here:
EXPO_PUBLIC_API_BASE_URL=https://daughter-chemist-resend.ngrok-free.dev

# (If you skip ngrok and your phone is on the SAME Wi-Fi, you can leave this
#  blank — the app auto-derives http://<your-laptop-LAN-ip>:3000 from Metro.
#  But uploaded images + Android release builds need HTTPS, so prefer ngrok.)
